# Copy this file to config/linux_server.env on the target Linux server.
# These values are machine-specific and should not be committed.

SEED_PROFILE=/absolute/path/to/linux_chromium_user_data_seed
PROFILE_NAME=Default
CHROME_PATH=/absolute/path/to/chrome
PYTHON_BIN=/absolute/path/to/python3

# Optional browser/runtime overrides.
PDF_BROWSER_NO_SANDBOX=
TMPDIR=
XDG_RUNTIME_DIR=

# Optional output root overrides.
RUNS_ROOT=/absolute/path/to/paper_download/outputs/linux_headless_suite_runs
LOGS_ROOT=/absolute/path/to/paper_download/logs
COLLECT_ROOT=/absolute/path/to/paper_download/outputs/collected_runs
